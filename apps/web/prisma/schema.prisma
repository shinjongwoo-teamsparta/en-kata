generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// NextAuth models
model User {
    id            String       @id @default(cuid())
    name          String?
    email         String?      @unique
    emailVerified DateTime?    @map("email_verified")
    image         String?
    accounts      Account[]
    sessions      Session[]
    gameResults   GameResult[]
    createdAt     DateTime     @default(now()) @map("created_at")
    updatedAt     DateTime     @updatedAt      @map("updated_at")

    @@map("users")
}

model Account {
    id                String  @id @default(cuid())
    userId            String  @map("user_id")
    type              String
    provider          String
    providerAccountId String  @map("provider_account_id")
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@map("accounts")
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique @map("session_token")
    userId       String   @map("user_id")
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("sessions")
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
    @@map("verification_tokens")
}

// Game result
model GameResult {
    id             String   @id @default(cuid())
    userId         String   @map("user_id")
    user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    mode           String   // word | phrase | code | variableName
    difficulty     String   // easy | medium | hard
    duration       Int      // seconds
    convention     String?  // camelCase | snake_case | kebab-case | PascalCase
    language       String?  // typescript | python
    category       String?  // general | frontend | backend | devops | database

    wpm            Int
    cpm            Int
    accuracy       Float
    totalChars     Int      @map("total_chars")
    correctChars   Int      @map("correct_chars")
    totalWords     Int      @map("total_words")
    completedWords Int      @map("completed_words")
    mistakeMap     Json     @map("mistake_map")     // Record<string, number>
    wpmTimeline    Json     @map("wpm_timeline")    // { second: number; wpm: number }[]

    createdAt      DateTime @default(now()) @map("created_at")

    @@index([userId])
    @@index([userId, mode])
    @@index([userId, createdAt])
    @@index([mode, difficulty, duration, wpm])
    @@index([createdAt])
    @@map("game_results")
}
