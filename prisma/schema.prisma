generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// NextAuth models
model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    gameResults   GameResult[]
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// Game result
model GameResult {
    id             String   @id @default(cuid())
    userId         String
    user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    mode           String   // word | phrase | shortCode | variableName
    difficulty     String   // easy | medium | hard
    duration       Int      // seconds
    convention     String?  // camelCase | snake_case | kebab-case | PascalCase
    language       String?  // jsts | python
    category       String?  // general | frontend | backend | devops | database

    wpm            Int
    cpm            Int
    accuracy       Float
    totalChars     Int
    correctChars   Int
    totalWords     Int
    completedWords Int
    mistakeMap     Json     // Record<string, number>
    wpmTimeline    Json     // { second: number; wpm: number }[]

    createdAt      DateTime @default(now())

    @@index([userId])
    @@index([userId, mode])
    @@index([userId, createdAt])
}
